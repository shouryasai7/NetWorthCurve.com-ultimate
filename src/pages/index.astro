const ALL_CURRENCIES = {};
CURRENCY_DATA.fiat.forEach(c => { ALL_CURRENCIES[c.code] = c.sym; });

let CUR = 'USD';
function sym(){ return ALL_CURRENCIES[CUR] || CUR; }
function fmt(v){ return sym()+Math.abs(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:2}); }
function fmtS(v){
  const a=Math.abs(v);
  if(a>=1e9) return sym()+(a/1e9).toFixed(1)+'B';
  if(a>=1e6) return sym()+(a/1e6).toFixed(1)+'M';
  if(a>=1e3) return sym()+(a/1e3).toFixed(0)+'K';
  return sym()+a.toFixed(0);
}
function sumC(cls){ let t=0; document.querySelectorAll('.'+cls).forEach(el=>{ const v=parseFloat(el.value); if(!isNaN(v)) t+=v; }); return t; }
function setT(id,v){ const el=document.getElementById(id); if(el) el.textContent=Math.abs(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:2}); }

function recalc(){
  const ta=sumC('nw-asset'), tl=sumC('nw-liability'), nw=ta-tl;
  setT('a-assets-hd',ta); setT('nw-ta',ta);
  setT('a-liab-hd',tl); setT('nw-tl',tl);
  setT('nw-value',Math.abs(nw));
  const nb=document.getElementById('nw-result'), nt=document.getElementById('nw-tip');
  if(nb){ nb.classList.remove('positive','negative'); if(nw>0) nb.classList.add('positive'); else if(nw<0) nb.classList.add('negative'); }
  if(nt){
    if(ta===0&&tl===0) nt.textContent='Enter your assets and liabilities to calculate net worth.';
    else if(nw>0) nt.textContent='Positive net worth of '+fmt(nw)+'. Your assets exceed liabilities. Consider investing surplus.';
    else if(nw<0) nt.textContent='Negative net worth. Focus on paying down high-interest debt first.';
    else nt.textContent='Breakeven — assets equal liabilities.';
  }
  const ti=sumC('cf-inc'), te=sumC('cf-exp'), cf=ti-te;
  setT('cf-inc-hd',ti); setT('cf-ti',ti);
  setT('cf-exp-hd',te); setT('cf-te',te);
  setT('cf-value',Math.abs(cf));
  const cb=document.getElementById('cf-result'), ct=document.getElementById('cf-tip');
  if(cb){ cb.classList.remove('positive','negative'); if(cf>0) cb.classList.add('positive'); else if(cf<0) cb.classList.add('negative'); }
  if(ct){
    if(ti===0&&te===0) ct.textContent='Enter your income and monthly expenses to calculate cashflow.';
    else if(cf>0) ct.textContent='Positive cashflow of '+fmt(cf)+'/month. Invest this surplus to build wealth.';
    else if(cf<0) ct.textContent='Negative cashflow. Expenses exceed income by '+fmt(Math.abs(cf))+'/month. Reduce costs or increase income.';
    else ct.textContent='Breakeven cashflow. Aim for positive surplus to invest.';
  }
  recalcProj();
  recalcSI();
}

function recalcProj(){
  const p=parseFloat(document.getElementById('principal')?.value)||0;
  const m=parseFloat(document.getElementById('monthly')?.value)||0;
  const r=(parseFloat(document.getElementById('rate')?.value)||0)/100;
  const y=parseFloat(document.getElementById('years')?.value)||1;
  const n=12, totalIn=p+(m*12*y);
  let fv=totalIn;
  if(r>0) fv=p*Math.pow(1+r/n,n*y)+(m>0?m*((Math.pow(1+r/n,n*y)-1)/(r/n)):0);
  const interest=Math.max(0,fv-totalIn);
  const pi=document.getElementById('proj-invested'), ii=document.getElementById('proj-interest'), fi=document.getElementById('proj-future');
  if(pi) pi.innerHTML='<span class="cs">'+sym()+'</span>'+totalIn.toLocaleString('en-US',{maximumFractionDigits:0});
  if(ii) ii.innerHTML='<span class="cs">'+sym()+'</span>'+interest.toLocaleString('en-US',{maximumFractionDigits:0});
  if(fi) fi.innerHTML='<span class="cs">'+sym()+'</span>'+fv.toLocaleString('en-US',{maximumFractionDigits:0});
  drawChart(p,m,r,n);
}

function drawChart(p,m,r,n){
  const canvas=document.getElementById('chart'); if(!canvas) return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const light=document.documentElement.classList.contains('light-mode');
  ctx.fillStyle=light?'#f8fffe':'#111'; ctx.fillRect(0,0,W,H);
  const data=[];
  for(let yr=0;yr<=10;yr++){
    const inv=p+(m*12*yr);
    let tot=inv;
    if(r>0) tot=p*Math.pow(1+r/n,n*yr)+(m>0?m*((Math.pow(1+r/n,n*yr)-1)/(r/n)):0);
    data.push({yr,inv,tot});
  }
  const pad={t:25,r:25,b:38,l:65}, cw=W-pad.l-pad.r, ch=H-pad.t-pad.b;
  const mx=Math.max(...data.map(d=>d.tot),1), sc=ch/(mx*1.1);
  ctx.strokeStyle=light?'rgba(0,0,0,0.06)':'rgba(255,255,255,0.04)'; ctx.lineWidth=1;
  for(let i=0;i<=5;i++){ const y=pad.t+(ch/5)*i; ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(W-pad.r,y); ctx.stroke(); }
  ctx.fillStyle=light?'#4b7a62':'#666'; ctx.font='10px JetBrains Mono,monospace';
  ctx.textAlign='center';
  for(let i=0;i<=10;i++) ctx.fillText('Y'+i,pad.l+(cw/10)*i,H-pad.b+16);
  ctx.textAlign='right';
  for(let i=0;i<=5;i++){ const y=pad.t+(ch/5)*i; ctx.fillText(fmtS(mx*1.1*(5-i)/5),pad.l-6,y+4); }
  if(data[data.length-1].tot>0&&r>0){
    ctx.beginPath();
    data.forEach((d,i)=>{ const x=pad.l+(cw/10)*d.yr, y=pad.t+ch-d.inv*sc; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
    [...data].reverse().forEach(d=>{ const x=pad.l+(cw/10)*d.yr, y=pad.t+ch-d.tot*sc; ctx.lineTo(x,y); });
    ctx.closePath(); ctx.fillStyle='rgba(46,204,113,0.12)'; ctx.fill();
  }
  ctx.strokeStyle=light?'#aaa':'#555'; ctx.lineWidth=2; ctx.beginPath();
  data.forEach((d,i)=>{ const x=pad.l+(cw/10)*d.yr, y=pad.t+ch-d.inv*sc; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); }); ctx.stroke();
  ctx.strokeStyle='#2ecc71'; ctx.lineWidth=3; ctx.beginPath();
  data.forEach((d,i)=>{ const x=pad.l+(cw/10)*d.yr, y=pad.t+ch-d.tot*sc; i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); }); ctx.stroke();
  data.forEach(d=>{ const x=pad.l+(cw/10)*d.yr, y=pad.t+ch-d.tot*sc; ctx.beginPath(); ctx.arc(x,y,4,0,Math.PI*2); ctx.fillStyle='#2ecc71'; ctx.fill(); ctx.strokeStyle=light?'#f8fffe':'#111'; ctx.lineWidth=1.5; ctx.stroke(); });
  const ys=document.getElementById('yr-stats');
  if(ys) ys.innerHTML=data.slice(1).map(d=>`<div class="ys"><span class="ys-yr">Yr ${d.yr}</span><span class="ys-val">${fmtS(d.tot)}</span></div>`).join('');
}

function setupCurrency(){
  const trigger = document.getElementById('cur-trigger');
  const panel   = document.getElementById('cur-panel');
  const search  = document.getElementById('cur-search');
  const list    = document.getElementById('cur-list');
  const tSym    = document.getElementById('cur-t-sym');
  const tName   = document.getElementById('cur-t-name');
  const tCode   = document.getElementById('cur-t-code');

  function buildList(query){
    list.innerHTML = '';
    const q = query.trim().toLowerCase();
    const items = CURRENCY_DATA.fiat;
    const filtered = q ? items.filter(c => c.name.toLowerCase().includes(q) || c.code.toLowerCase().includes(q)) : items;
    if (!filtered.length) {
      list.innerHTML = '<div class="cur-no-results">No currencies found</div>';
      return;
    }
    filtered.forEach(c => {
      const opt = document.createElement('div');
      opt.className = 'cur-option' + (c.code === CUR ? ' selected' : '');
      opt.setAttribute('role', 'option');
      opt.dataset.code = c.code;
      opt.innerHTML = `<span class="cur-opt-sym">${c.sym}</span><span class="cur-opt-name">${c.name}</span><span class="cur-opt-code">${c.code}</span>`;
      opt.addEventListener('click', () => selectCurrency(c));
      list.appendChild(opt);
    });
  }

  function selectCurrency(c){
    CUR = c.code;
    tSym.textContent  = c.sym;
    tName.textContent = c.name;
    tCode.textContent = c.code;
    closePanel();
    document.querySelectorAll('.cs:not(.bullion-cs):not(.crypto-cs)').forEach(el => el.textContent = sym());
    recalc();
  }

  function openPanel(){
    panel.hidden = false;
    trigger.setAttribute('aria-expanded', 'true');
    search.value = '';
    buildList('');
    search.focus();
    const selected = list.querySelector('.selected');
    if (selected) selected.scrollIntoView({ block:'nearest' });
  }

  function closePanel(){
    panel.hidden = true;
    trigger.setAttribute('aria-expanded', 'false');
  }

  trigger.addEventListener('click', () => {
    if (panel.hidden) openPanel(); else closePanel();
  });

  search.addEventListener('input', () => buildList(search.value));

  document.addEventListener('click', e => {
    if (!trigger.contains(e.target) && !panel.contains(e.target)) closePanel();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closePanel();
  });

  buildList('');
}

function setupAssetPickers(){
  /* Bullion picker */
  document.querySelectorAll('#bullion-picker .ap-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#bullion-picker .ap-btn').forEach(b => b.classList.remove('ap-active'));
      btn.classList.add('ap-active');
      document.querySelector('.bullion-cs').textContent = btn.dataset.sym;
    });
  });

  /* Crypto picker */
  document.querySelectorAll('#crypto-picker .ap-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#crypto-picker .ap-btn').forEach(b => b.classList.remove('ap-active'));
      btn.classList.add('ap-active');
      document.querySelector('.crypto-cs').textContent = btn.dataset.sym;
    });
  });
}

function setupRows(){
  document.querySelectorAll('.add-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const listId=btn.dataset.list, cls=btn.dataset.class;
      const list=document.getElementById(listId); if(!list) return;
      const name=prompt('Enter category name:');
      if(!name||!name.trim()) return;
      const row=document.createElement('div'); row.className='row-item custom-row';
      row.innerHTML=`<label>${name.trim()}</label><div class="field"><span class="cs">${sym()}</span><input type="number" class="fi ${cls}" placeholder="0" min="0" step="0.01"/></div><button type="button" class="rm-btn" aria-label="Remove row" title="Remove">&#x2715;</button>`;
      list.appendChild(row);
      row.querySelector('.fi').addEventListener('input',recalc);
      row.querySelector('.rm-btn').addEventListener('click',()=>{ row.remove(); recalc(); });
    });
  });
}

function gatherRows(listId,cat){
  const rows=[];
  document.querySelectorAll('#'+listId+' .row-item').forEach(row=>{
    let label = row.querySelector('label')?.textContent.trim() || '';
    if (!label) {
      const title = row.querySelector('.asset-picker-title')?.textContent.trim() || '';
      const active = row.querySelector('.ap-btn.ap-active');
      label = active ? title + ' — ' + active.dataset.name : title;
    }
    const val=parseFloat(row.querySelector('.fi')?.value)||0;
    if(val!==0) rows.push({cat,name:label,amount:val});
  });
  return rows;
}

function exportCSV(type){
  let rows=[], title='', summary='';
  if(type==='nw'){
    rows=[...gatherRows('nw-assets','Asset'),...gatherRows('nw-liabilities','Liability')];
    const ta=sumC('nw-asset'), tl=sumC('nw-liability');
    summary=`\nTotal Assets,,${ta}\nTotal Liabilities,,${tl}\nNet Worth,,${ta-tl}`;
    title='Sovereign Net Worth Report';
  } else {
    rows=[...gatherRows('cf-income','Income'),...gatherRows('cf-expenses','Expense')];
    const ti=sumC('cf-inc'), te=sumC('cf-exp');
    summary=`\nTotal Income,,${ti}\nTotal Expenses,,${te}\nMonthly Cashflow,,${ti-te}`;
    title='Monthly Cashflow Report';
  }
  let csv=`${title}\nDate,${new Date().toLocaleDateString()}\nCurrency,${CUR}\n\nCategory,Name,Amount\n`;
  rows.forEach(r=>{ csv+=`${r.cat},"${r.name}",${r.amount}\n`; });
  csv+=summary;
  const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([csv],{type:'text/csv'})),download:`networthcurve-${type}-${new Date().toISOString().slice(0,10)}.csv`});
  a.click(); URL.revokeObjectURL(a.href);
}

function exportPDF(type){
  let secs=[], title='', resultLabel='', resultValue=0;
  if(type==='nw'){
    const ta=sumC('nw-asset'), tl=sumC('nw-liability');
    resultLabel='Net Worth'; resultValue=ta-tl; title='Sovereign Net Worth Report';
    secs=[{h:'Assets',rows:gatherRows('nw-assets','Asset'),total:ta},{h:'Liabilities',rows:gatherRows('nw-liabilities','Liability'),total:tl}];
  } else {
    const ti=sumC('cf-inc'), te=sumC('cf-exp');
    resultLabel='Monthly Cashflow'; resultValue=ti-te; title='Monthly Cashflow Report';
    secs=[{h:'Income',rows:gatherRows('cf-income','Income'),total:ti},{h:'Expenses',rows:gatherRows('cf-expenses','Expense'),total:te}];
  }
  const s=sym(), fp=v=>s+Math.abs(v).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  let tables=secs.map(sec=>`<h3>${sec.h}</h3><table><thead><tr><th>Name</th><th>Amount</th></tr></thead><tbody>${sec.rows.map(r=>`<tr><td>${r.name}</td><td>${fp(r.amount)}</td></tr>`).join('')}<tr class="tr"><td>Total ${sec.h}</td><td>${fp(sec.total)}</td></tr></tbody></table>`).join('');
  const isPos=resultValue>=0;
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${title}</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Segoe UI',sans-serif;padding:40px;color:#1a1a1a}.hd{text-align:center;padding-bottom:15px;margin-bottom:20px;border-bottom:2px solid #2ecc71}.hd h1{font-size:20px;color:#145a34}.hd p{font-size:11px;color:#666;margin-top:4px}h3{font-size:13px;color:#145a34;background:#e8f8f0;padding:6px 10px;border-radius:4px;margin:16px 0 8px}table{width:100%;border-collapse:collapse;margin-bottom:10px}th,td{padding:8px 10px;border-bottom:1px solid #e8e8e8;font-size:12px}th{background:#f5f5f5;font-weight:600}td:last-child{text-align:right;font-family:monospace}.tr{font-weight:700;background:#f9f9f9}.rbox{text-align:center;padding:20px;border-radius:8px;margin:20px 0;background:${isPos?'linear-gradient(135deg,#145a34,#2ecc71)':'linear-gradient(135deg,#c0392b,#e74c3c)'};color:#fff}.rl{font-size:11px;text-transform:uppercase;letter-spacing:2px;opacity:.85}.rv{font-size:30px;font-weight:700;font-family:monospace;margin-top:4px}.ft{margin-top:25px;text-align:center;font-size:10px;color:#999;border-top:1px solid #e8e8e8;padding-top:12px}</style></head><body><div class="hd"><h1>NetWorthCurve.com</h1><p>${title} &mdash; ${new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})} &mdash; ${CUR}</p></div>${tables}<div class="rbox"><div class="rl">${resultLabel}</div><div class="rv">${resultValue<0?'-':''}${fp(Math.abs(resultValue))}</div></div><div class="ft">Generated by NetWorthCurve.com</div></body></html>`;
  const w=window.open('','','width=850,height=700');
  if(w){ w.document.write(html); w.document.close(); w.onload=()=>w.print(); }
}

function setupCalcTabs(){
  document.querySelectorAll('.calc-tab').forEach(tab=>{
    tab.addEventListener('click',()=>{
      const target=tab.dataset.tab;
      document.querySelectorAll('.calc-tab').forEach(t=>t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('.tab-pane').forEach(p=>{ p.hidden=(p.id!=='tab-'+target); });
    });
  });
}

let siMode='invest', siUnit='y';

function recalcSI(){
  const p=parseFloat(document.getElementById('si-p')?.value)||0;
  const r=parseFloat(document.getElementById('si-r')?.value)||0;
  const tRaw=parseFloat(document.getElementById('si-t')?.value)||0;
  const tYears=siUnit==='m'?tRaw/12:tRaw;
  const si=(p*r*tYears)/100;
  const total=p+si;
  const emi=(siMode==='loan'&&tYears>0)?total/(tYears*12):0;
  const cs=sym();
  const setStat=(id,val)=>{ const el=document.getElementById(id); if(el) el.innerHTML='<span class="cs">'+cs+'</span>'+Math.abs(val).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); };
  setStat('sst-p',p); setStat('sst-int',si); setStat('sst-tot',total);
  if(siMode==='loan') setStat('sst-emi',emi);
  const emiWrap=document.getElementById('sst-emi-wrap');
  const emiFml=document.getElementById('si-fml-emi');
  if(emiWrap) emiWrap.style.display=siMode==='loan'?'block':'none';
  if(emiFml) emiFml.style.display=siMode==='loan'?'inline':'none';
}

function setupSI(){
  document.querySelectorAll('.si-mbtn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      siMode=btn.dataset.mode;
      document.querySelectorAll('.si-mbtn').forEach(b=>b.classList.remove('si-active'));
      btn.classList.add('si-active');
      const head=document.getElementById('si-chead'), body=document.getElementById('si-cbody');
      const intLbl=document.getElementById('sst-intlbl'), totLbl=document.getElementById('sst-totlbl');
      if(siMode==='invest'){
        if(head) head.textContent='Simple Interest \u2014 Investment Mode';
        if(body) body.innerHTML='Calculates interest on the <strong>principal only</strong>. Ideal for fixed deposits, treasury bills, and short-term savings. Formula: <strong>SI = (P \u00D7 R \u00D7 T) / 100</strong>';
        if(intLbl) intLbl.textContent='Interest Earned';
        if(totLbl) totLbl.textContent='Total Amount';
      } else {
        if(head) head.textContent='Simple Interest \u2014 Loan Mode';
        if(body) body.innerHTML='Calculate total interest on a loan and monthly installments. For personal loans, car loans, short-term credit. <strong>SI = (P \u00D7 R \u00D7 T) / 100</strong>, <strong>Monthly = (P + SI) / Months</strong>';
        if(intLbl) intLbl.textContent='Total Interest Payable';
        if(totLbl) totLbl.textContent='Total Amount Payable';
      }
      recalcSI();
    });
  });
  document.querySelectorAll('.si-tu').forEach(btn=>{
    btn.addEventListener('click',()=>{
      siUnit=btn.dataset.u;
      document.querySelectorAll('.si-tu').forEach(b=>b.classList.remove('si-tu-on'));
      btn.classList.add('si-tu-on');
      const sfx=document.getElementById('si-tsfx'); if(sfx) sfx.textContent=siUnit==='y'?'yrs':'mo';
      recalcSI();
    });
  });
  document.getElementById('si-pdf')?.addEventListener('click',()=>exportSIPDF());
  document.getElementById('si-csv')?.addEventListener('click',()=>exportSICSV());
}

