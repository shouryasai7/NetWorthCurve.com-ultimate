.fi { flex:1; padding:7px; background:transparent; border:none; color:#fff; font-family:var(--font-mono); font-size:.88rem; font-weight:500; outline:none; text-align:right; min-width:60px; }
.fi::placeholder { color:var(--charcoal-500); }
.fi::-webkit-outer-spin-button,.fi::-webkit-inner-spin-button { -webkit-appearance:none; margin:0; }

.add-btn { width:calc(100% - 1.5rem); margin:0 .75rem .75rem; padding:.55rem; background:transparent; border:1px dashed var(--charcoal-500); border-radius:7px; color:var(--emerald-400); font-size:.78rem; font-weight:600; cursor:pointer; transition:all .15s; }
.add-btn:hover { border-color:var(--emerald-500); background:rgba(46,204,113,.04); }

.panel-foot { display:flex; align-items:center; justify-content:space-between; padding:.75rem 1.2rem; border-top:1px solid var(--charcoal-700); }
.pos-foot { background:rgba(46,204,113,.05); border-top-color:rgba(46,204,113,.2); }
.neg-foot { background:rgba(192,57,43,.05); border-top-color:rgba(192,57,43,.2); }
.panel-foot > span:first-child { font-size:.8rem; font-weight:600; color:var(--charcoal-300); }
.fval { font-family:var(--font-mono); font-size:1.05rem; font-weight:700; }
.fpos { color:var(--emerald-400); }
.fneg { color:var(--crimson-400); }

.result-box { margin-top:1.5rem; background:var(--charcoal-900); border:1px solid var(--charcoal-600); border-radius:14px; overflow:hidden; transition:all .2s; }
.result-box.positive { border-color:var(--emerald-600); box-shadow:0 0 25px rgba(46,204,113,.12); }
.result-box.negative { border-color:var(--crimson-600); box-shadow:0 0 25px rgba(192,57,43,.12); }
.rbox-bar { display:flex; align-items:center; gap:.5rem; padding:.7rem 1rem; background:var(--charcoal-850); border-bottom:1px solid var(--charcoal-700); }
.dot-r { width:10px; height:10px; border-radius:50%; background:#ff5f56; }
.dot-y { width:10px; height:10px; border-radius:50%; background:#ffbd2e; }
.dot-g { width:10px; height:10px; border-radius:50%; background:#27ca40; }
.rbox-lbl { margin-left:auto; font-family:var(--font-mono); font-size:.62rem; font-weight:600; color:var(--charcoal-400); letter-spacing:.15em; }
.rbox-body { padding:2rem; text-align:center; }
.big-val { display:flex; align-items:baseline; justify-content:center; gap:.5rem; margin-bottom:1rem; }
.rcs { font-size:1.3rem; color:var(--charcoal-400); }
.big-val > span:last-child { font-family:var(--font-mono); font-size:clamp(1.8rem,5vw,2.8rem); font-weight:700; color:var(--charcoal-100); }
.result-box.positive .big-val > span:last-child { color:var(--emerald-400); }
.result-box.negative .big-val > span:last-child { color:var(--crimson-400); }
.rbox-body p { font-size:.85rem; color:var(--charcoal-400); max-width:480px; margin:0 auto; line-height:1.5; }

.exp-row { display:flex; gap:.75rem; justify-content:center; margin-top:1.2rem; flex-wrap:wrap; }
.exp-btn { padding:.55rem 1.4rem; background:var(--charcoal-800); border:1px solid var(--charcoal-500); border-radius:7px; color:var(--charcoal-200); font-size:.82rem; font-weight:600; cursor:pointer; transition:all .15s; }
.exp-btn:hover { border-color:var(--emerald-500); color:var(--emerald-400); }

.concept-box { padding:1.25rem 1.5rem; margin-bottom:1.75rem; background:rgba(46,204,113,.05); border:1px solid rgba(46,204,113,.18); border-radius:10px; }
.concept-box h4 { font-size:.92rem; color:var(--emerald-300); margin:0 0 .6rem; }
.concept-box p { font-size:.88rem; color:var(--charcoal-200); line-height:1.7; margin:0; }
.concept-box strong { color:#fff; }

.proj-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; }
@media(min-width:900px){.proj-grid{grid-template-columns:1fr 1fr; align-items:start;}}
.proj-inputs { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
@media(max-width:480px){.proj-inputs{grid-template-columns:1fr;}}
.input-card { background:var(--charcoal-850); border:1px solid var(--charcoal-600); border-radius:10px; padding:1rem; }
.input-card h4 { font-size:.82rem; font-weight:600; color:var(--charcoal-200); margin:0 0 .6rem; }
.proj-stats { display:flex; flex-direction:column; gap:.75rem; }
.pstat { padding:1.2rem; background:var(--charcoal-850); border:1px solid var(--charcoal-700); border-radius:10px; text-align:center; }
.pstat.accent { border-color:rgba(46,204,113,.3); background:rgba(46,204,113,.05); }
.pstat.total { background:var(--emerald-900); border-color:var(--emerald-700); }
.psl { display:block; font-size:.68rem; color:var(--charcoal-400); text-transform:uppercase; letter-spacing:.1em; margin-bottom:.4rem; }
.psv { font-family:var(--font-mono); font-size:1.3rem; font-weight:700; color:#fff; }
.pstat.accent .psv { color:var(--emerald-400); }
.pstat.total .psv { color:var(--emerald-300); }
.psv.big { font-size:1.6rem; }

.graph-wrap { margin-top:2.5rem; background:var(--charcoal-850); border:1px solid var(--charcoal-600); border-radius:14px; padding:1.5rem; }
.graph-title { font-size:1.15rem; text-align:center; margin:0 0 .4rem; }
.graph-sub { font-size:.8rem; color:var(--charcoal-400); text-align:center; margin:0 0 1.2rem; }
.canvas-box { background:var(--charcoal-900); border:1px solid var(--charcoal-700); border-radius:8px; padding:.75rem; margin-bottom:1rem; overflow-x:auto; }
#chart { width:100%; height:300px; display:block; }
.chart-leg { display:flex; justify-content:center; gap:1.5rem; margin-bottom:1rem; flex-wrap:wrap; }
.leg-i { display:flex; align-items:center; gap:.4rem; font-size:.78rem; color:var(--charcoal-300); }
.leg-dot { width:12px; height:12px; border-radius:3px; }
.dgray { background:var(--charcoal-400); }
.dgreen { background:var(--emerald-500); }
.yr-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(80px,1fr)); gap:.4rem; }
.ys { text-align:center; padding:.5rem .4rem; background:var(--charcoal-800); border:1px solid var(--charcoal-700); border-radius:6px; }
.ys-yr { display:block; font-size:.58rem; color:var(--charcoal-500); text-transform:uppercase; }
.ys-val { font-family:var(--font-mono); font-size:.72rem; font-weight:600; color:var(--emerald-400); }

.support-section { padding:4rem 0; }
.support-card { max-width:640px; margin:0 auto; text-align:center; padding:2.5rem 2rem; background:var(--charcoal-850); border:1px solid var(--charcoal-600); border-radius:16px; }
.s-icon { width:52px; height:52px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,var(--emerald-800),var(--emerald-700)); border-radius:50%; margin:0 auto 1.2rem; }
.s-icon svg { width:26px; height:26px; color:var(--emerald-300); }
.support-card h2 { font-size:1.35rem; margin:0 0 1rem; }
.support-card p { font-size:.88rem; color:var(--charcoal-200); line-height:1.75; margin:0 0 .9rem; }
.kofi-btn { display:inline-flex; align-items:center; text-decoration:none; transition:transform .2s; margin:.5rem 0; }
.kofi-btn:hover { transform:translateY(-2px); }
.s-note { font-size:.72rem; color:var(--charcoal-500); margin:0; }

.content-section,.faq-section { padding:3.5rem 0; border-top:1px solid var(--charcoal-700); }
.content-wrap { max-width:720px; margin:0 auto; padding:0 1rem; }
.content-wrap h2 { font-size:clamp(1.2rem,3vw,1.6rem); margin:0 0 1.2rem; }
.content-wrap h3 { font-size:1.05rem; color:var(--emerald-300); margin:2rem 0 .6rem; }
.lead { font-size:1rem; color:var(--charcoal-100); line-height:1.8; margin-bottom:1.5rem; }
.content-wrap p { font-size:.9rem; color:var(--charcoal-200); line-height:1.8; margin:0 0 1rem; }
.content-wrap strong { color:#fff; }

.faq { background:var(--charcoal-800); border:1px solid var(--charcoal-600); border-radius:8px; margin-bottom:.6rem; overflow:hidden; }
.faq[open] { border-color:var(--emerald-700); }
.faq summary { padding:.9rem 1rem; font-size:.88rem; font-weight:600; color:var(--charcoal-100); cursor:pointer; list-style:none; }
.faq summary::-webkit-details-marker { display:none; }
.faq[open] summary { color:var(--emerald-300); }
.faq p { padding:0 1rem .9rem; font-size:.85rem; color:var(--charcoal-300); line-height:1.65; margin:0; }

/* Engine C tabs */
.calc-tabs { display:flex; gap:.4rem; margin-bottom:1.75rem; background:var(--charcoal-800); padding:.3rem; border-radius:10px; border:1px solid var(--charcoal-600); width:fit-content; margin-left:auto; margin-right:auto; }
.calc-tab { display:inline-flex; align-items:center; gap:.45rem; padding:.5rem 1.4rem; background:transparent; border:none; border-radius:7px; color:var(--charcoal-300); font-size:.84rem; font-weight:600; cursor:pointer; transition:all .2s; font-family:var(--font-display); }
.calc-tab.active { background:var(--emerald-800); color:#fff; box-shadow:0 2px 10px rgba(46,204,113,.25); }
.calc-tab:hover:not(.active) { color:var(--emerald-300); }
.tab-pane[hidden] { display:none; }

/* Simple Interest mode row */
.si-mode-row { display:flex; gap:.5rem; justify-content:center; margin-bottom:1.25rem; }
.si-mbtn { display:inline-flex; align-items:center; gap:.45rem; padding:.55rem 1.4rem; background:var(--charcoal-800); border:1px solid var(--charcoal-600); border-radius:8px; color:var(--charcoal-300); font-size:.82rem; font-weight:600; cursor:pointer; transition:all .2s; font-family:var(--font-display); }
.si-mbtn.si-active { background:var(--emerald-800); border-color:var(--emerald-600); color:#fff; }
.si-mbtn:hover:not(.si-active) { border-color:var(--emerald-600); color:var(--emerald-300); }

/* SI time period row */
.si-trow { display:flex; align-items:center; gap:.5rem; }
.si-tunit { display:flex; border-radius:6px; overflow:hidden; border:1px solid var(--charcoal-600); flex-shrink:0; }
.si-tu { padding:.38rem .65rem; background:var(--charcoal-800); border:none; color:var(--charcoal-400); font-size:.7rem; font-weight:600; cursor:pointer; transition:all .15s; font-family:var(--font-display); }
.si-tu.si-tu-on { background:var(--emerald-800); color:#fff; }
.si-tu:hover:not(.si-tu-on) { color:var(--emerald-400); }

/* SI formula bar */
.si-fml { display:flex; align-items:center; gap:.75rem; margin-top:1.5rem; padding:.9rem 1.25rem; background:var(--charcoal-800); border:1px solid var(--charcoal-600); border-radius:10px; flex-wrap:wrap; }
.si-fml-lbl { font-family:var(--font-mono); font-size:.6rem; font-weight:700; color:var(--emerald-400); letter-spacing:.15em; flex-shrink:0; }
.si-fml code { font-family:var(--font-mono); font-size:.88rem; color:var(--charcoal-100); }

/* Asset picker rows (bullion & crypto) */
.row-item--bullion, .row-item--crypto { align-items:flex-start; flex-wrap:wrap; gap:.5rem .75rem; }
.asset-picker-label { flex:1; min-width:0; display:flex; flex-direction:column; gap:.45rem; }
.asset-picker-title { font-size:.72rem; font-weight:700; color:var(--charcoal-400); text-transform:uppercase; letter-spacing:.1em; }
.asset-picker { display:flex; gap:.35rem; flex-wrap:wrap; }
.ap-btn { display:inline-flex; align-items:center; gap:.35rem; padding:.3rem .65rem; background:var(--charcoal-800); border:1px solid var(--charcoal-600); border-radius:20px; cursor:pointer; transition:all .15s; font-family:var(--font-display); }
.ap-sym { font-family:var(--font-mono); font-size:.78rem; font-weight:700; }
.ap-name { font-size:.7rem; font-weight:600; color:var(--charcoal-300); }

/* Bullion active state — amber/gold */
.row-item--bullion .ap-btn { border-color:var(--charcoal-600); }
.row-item--bullion .ap-btn .ap-sym { color:#f59e0b; }
.row-item--bullion .ap-btn.ap-active { background:rgba(245,158,11,.12); border-color:rgba(245,158,11,.5); }
.row-item--bullion .ap-btn.ap-active .ap-sym { color:#fbbf24; }
.row-item--bullion .ap-btn.ap-active .ap-name { color:#fde68a; }
.row-item--bullion .ap-btn:hover:not(.ap-active) { border-color:rgba(245,158,11,.35); }
.bullion-cs { color:#f59e0b !important; background:rgba(245,158,11,.12) !important; min-width:38px; text-align:center; }

/* Crypto active state — sky blue */
.row-item--crypto .ap-btn .ap-sym { color:#60a5fa; }
.row-item--crypto .ap-btn.ap-active { background:rgba(96,165,250,.1); border-color:rgba(96,165,250,.45); }
.row-item--crypto .ap-btn.ap-active .ap-sym { color:#93c5fd; }
.row-item--crypto .ap-btn.ap-active .ap-name { color:#bfdbfe; }
.row-item--crypto .ap-btn:hover:not(.ap-active) { border-color:rgba(96,165,250,.35); }
.crypto-cs { color:#60a5fa !important; background:rgba(96,165,250,.1) !important; min-width:30px; text-align:center; }

@media(max-width:640px){
.hero-metrics{flex-direction:column;gap:1rem;}
.metric-divider{width:40px;height:1px;}
.cur-dropdown-wrap{max-width:100%;}
.row-item--bullion,.row-item--crypto{flex-direction:column;}
.row-item--bullion .field,.row-item--crypto .field{width:100%;}
.row-item{flex-wrap:wrap;gap:.5rem;}
.row-item label{flex:1 0 100%;}
.field{width:100%;}
.exp-row{flex-direction:column;align-items:stretch;}
.exp-btn{text-align:center;}
.proj-inputs{grid-template-columns:1fr;}
.support-card{padding:1.5rem 1rem;}
}

