  const s=sym(), fp=v=>s+Math.abs(v).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  const modeLabel=siMode==='invest'?'Investment':'Loan';
  const timeLabel=tRaw+' '+(siUnit==='y'?'Years':'Months')+' ('+tYears.toFixed(2)+' yrs)';
  const emiRow=siMode==='loan'?`<tr><td>Monthly Installment</td><td>${fp(emi)}</td></tr>`:'';
  const isLoan=siMode==='loan';
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Simple Interest Report</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Segoe UI',sans-serif;padding:40px;color:#1a1a1a}.hd{text-align:center;padding-bottom:15px;margin-bottom:20px;border-bottom:2px solid #2ecc71}.hd h1{font-size:20px;color:#145a34}.hd p{font-size:11px;color:#666;margin-top:4px}.mode-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-top:6px;background:${isLoan?'#fee2e2':'#dcfce7'};color:${isLoan?'#b91c1c':'#15803d'}}h3{font-size:13px;color:#145a34;background:#e8f8f0;padding:6px 10px;border-radius:4px;margin:16px 0 8px}table{width:100%;border-collapse:collapse;margin-bottom:10px}th,td{padding:8px 10px;border-bottom:1px solid #e8e8e8;font-size:12px}th{background:#f5f5f5;font-weight:600}td:last-child{text-align:right;font-family:monospace}.highlight{font-weight:700;background:#f9f9f9}.fml{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:10px 14px;margin:12px 0;font-family:monospace;font-size:12px;color:#15803d}.rbox{text-align:center;padding:20px;border-radius:8px;margin:20px 0;background:${isLoan?'linear-gradient(135deg,#b91c1c,#ef4444)':'linear-gradient(135deg,#145a34,#2ecc71)'};color:#fff}.rl{font-size:11px;text-transform:uppercase;letter-spacing:2px;opacity:.85}.rv{font-size:28px;font-weight:700;font-family:monospace;margin-top:4px}.ft{margin-top:25px;text-align:center;font-size:10px;color:#999;border-top:1px solid #e8e8e8;padding-top:12px}</style></head><body><div class="hd"><h1>NetWorthCurve.com</h1><p>Simple Interest Report &mdash; ${new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})} &mdash; ${CUR}</p><span class="mode-badge">${modeLabel}</span></div><h3>Inputs</h3><table><thead><tr><th>Parameter</th><th>Value</th></tr></thead><tbody><tr><td>Principal Amount</td><td>${fp(p)}</td></tr><tr><td>Annual Interest Rate</td><td>${r}%</td></tr><tr><td>Time Period</td><td>${timeLabel}</td></tr></tbody></table><div class="fml">Formula: SI = (P &times; R &times; T) / 100${isLoan?' &nbsp;|&nbsp; EMI = (P + SI) / Months':''}</div><h3>Results</h3><table><thead><tr><th>Output</th><th>Value</th></tr></thead><tbody><tr><td>${isLoan?'Total Interest Payable':'Interest Earned'}</td><td>${fp(si)}</td></tr>${emiRow}<tr class="highlight"><td>${isLoan?'Total Amount Payable':'Total Amount'}</td><td>${fp(total)}</td></tr></tbody></table><div class="rbox"><div class="rl">${isLoan?'Total Repayment':'Total Amount'}</div><div class="rv">${fp(total)}</div></div><div class="ft">Generated by NetWorthCurve.com &mdash; Privacy-first financial tools</div></body></html>`;
  const w=window.open('','','width=850,height=700');
  if(w){ w.document.write(html); w.document.close(); w.onload=()=>w.print(); }
}

function exportSICSV(){
  const p=parseFloat(document.getElementById('si-p')?.value)||0;
  const r=parseFloat(document.getElementById('si-r')?.value)||0;
  const tRaw=parseFloat(document.getElementById('si-t')?.value)||0;
  const tYears=siUnit==='m'?tRaw/12:tRaw;
  const si=(p*r*tYears)/100, total=p+si;
  const emi=(siMode==='loan'&&tYears>0)?total/(tYears*12):0;
  let csv=`Simple Interest Report\nDate,${new Date().toLocaleDateString()}\nCurrency,${CUR}\nMode,${siMode==='invest'?'Investment':'Loan'}\n\nParameter,Value\nPrincipal,${p}\nAnnual Rate,${r}%\nTime,${tRaw} ${siUnit==='y'?'years':'months'}\n\nResult,Value\nSimple Interest,${si.toFixed(2)}\nTotal Amount,${total.toFixed(2)}`;
  if(siMode==='loan') csv+=`\nMonthly Installment,${emi.toFixed(2)}`;
  const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([csv],{type:'text/csv'})),download:`networthcurve-si-${new Date().toISOString().slice(0,10)}.csv`});
  a.click(); URL.revokeObjectURL(a.href);
}

function init(){
  setupCurrency();
  setupAssetPickers();
  setupRows();
  setupCalcTabs();
  setupSI();
  document.querySelectorAll('.fi').forEach(i=>i.addEventListener('input',recalc));
  document.getElementById('nw-pdf')?.addEventListener('click',()=>exportPDF('nw'));
  document.getElementById('nw-csv')?.addEventListener('click',()=>exportCSV('nw'));
  document.getElementById('cf-pdf')?.addEventListener('click',()=>exportPDF('cf'));
  document.getElementById('cf-csv')?.addEventListener('click',()=>exportCSV('cf'));
  drawChart(0,0,0,12);
}
if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init);
else init();
</script>
