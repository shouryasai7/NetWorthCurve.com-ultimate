---
const currentYear = new Date().getFullYear();

const footerLinks = {
	product: [
		{ href: '/', label: 'Net Worth Calculator' },
		{ href: '/#cashflow', label: 'Cashflow Calculator' },
		{ href: '/#projector', label: 'Compound Interest Generator' },
		{ href: '/#projector', label: 'Simple Interest Calculator' },
		{ href: '/#learn', label: 'Wealth Guide' }
	],
	company: [
		{ href: '/about', label: 'About Us' },
		{ href: '/contact', label: 'Contact' },
		{ href: '/privacy', label: 'Privacy Policy' },
		{ href: '/terms', label: 'Terms of Service' }
	],
	resources: [
		{ href: '/articles', label: 'Articles & Insights' },
		{ href: '/#faq', label: 'FAQ' },
		{ href: '/about#mission', label: 'Our Mission' },
		{ href: '/contact#support', label: 'Support' }
	]
};
---

<footer class="site-footer">
	<div class="footer-glow"></div>
	<div class="footer-container">
		<div class="footer-grid">
			<!-- Brand Column -->
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<div class="footer-logo-icon">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#33FF66" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 3v18h18"/>
							<path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
							<path d="M15 8h3.7V11.7"/>
						</svg>
					</div>
					<div class="footer-brand-text">
                    <span class="footer-brand-name">NetWorthCurve</span>
                    <span class="footer-brand-tld">.com</span>
              </div>
				</a>
				<p class="footer-tagline">Sovereign wealth management tools. Zero tracking. Zero cloud sync. Complete privacy.</p>
				<div class="footer-badges">
					<span class="footer-badge">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
							<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
						</svg>
						256-bit SSL
					</span>
					<span class="footer-badge">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
						</svg>
						Zero Data Collection
					</span>
				</div>
			</div>

			<!-- Links Columns -->
			<div class="footer-links-col">
				<h4 class="footer-heading">Product</h4>
				<ul class="footer-links">
					{footerLinks.product.map(link => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>

			<div class="footer-links-col">
				<h4 class="footer-heading">Company</h4>
				<ul class="footer-links">
					{footerLinks.company.map(link => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>

			<div class="footer-links-col">
				<h4 class="footer-heading">Resources</h4>
				<ul class="footer-links">
					{footerLinks.resources.map(link => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</div>
		</div>

		<div class="footer-divider"></div>

		<div class="footer-bottom">
			<p class="footer-copyright">
				&copy; {currentYear} NetWorthCurve.com. All rights reserved.
			</p>
			<p class="footer-disclaimer">
				This calculator is provided for educational purposes only. Not financial advice. Consult a licensed financial advisor for investment decisions.
			</p>
		</div>
	</div>

	<!-- Decorative Elements -->
	<div class="footer-decoration">
		<div class="decoration-line"></div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		background: linear-gradient(180deg, var(--charcoal-900) 0%, var(--charcoal-950) 100%);
		border-top: 1px solid rgba(46, 204, 113, 0.1);
		overflow: hidden;
	}

	.footer-glow {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--emerald-500), transparent);
		opacity: 0.5;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-12) var(--space-4) var(--space-8);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr;
		gap: var(--space-8);
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		text-decoration: none;
	}

	.footer-logo svg {
		width: 36px;
		height: 36px;
		border-radius: var(--radius-md);
	}

	.footer-logo-icon {
		width: 36px;
		height: 36px;
		min-width: 36px;
		background: #0a1a0f;
		border: 1px solid rgba(51, 255, 102, 0.3);
		border-radius: var(--radius-md);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 5px;
		box-shadow: 0 0 10px rgba(51, 255, 102, 0.15);
	}

	.footer-logo-icon svg {
		width: 100%;
		height: 100%;
	}

	.footer-logo-text {
		font-size: 1.1rem;
		font-weight: 700;
		color: #fff;
		letter-spacing: -0.02em;
	}'
    .footer-brand-text {
    display: flex;
    align-items: baseline;
    font-weight: 700;
    font-size: 1.25rem;
  }

    .footer-brand-name {
    color: var(--text-primary, #ffffff);
  }

    /* This targets the .com and locks it into your accent green */
    .footer-brand-tld {
    color: #33FF66 !important;
    font-size: 1.25rem;
  }

	.footer-tagline {
		font-size: 0.9rem;
		color: var(--charcoal-400);
		line-height: 1.6;
		max-width: 280px;
	}

	.footer-badges {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.footer-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--space-1);
		padding: var(--space-1) var(--space-2);
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--emerald-400);
		background: rgba(46, 204, 113, 0.1);
		border: 1px solid rgba(46, 204, 113, 0.2);
		border-radius: var(--radius-sm);
	}

	.footer-badge svg {
		width: 12px;
		height: 12px;
	}

	.footer-links-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.footer-heading {
		font-size: 0.8rem;
		font-weight: 700;
		color: #fff;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.footer-links {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.footer-links a {
		font-size: 0.9rem;
		color: var(--charcoal-400);
		transition: color var(--transition-fast);
	}

	.footer-links a:hover {
		color: var(--emerald-400);
	}

	.footer-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--charcoal-600), transparent);
		margin: var(--space-8) 0;
	}

	.footer-bottom {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-3);
		text-align: center;
	}

	.footer-copyright {
		font-size: 0.85rem;
		color: var(--charcoal-300);
	}

	.footer-disclaimer {
		font-size: 0.75rem;
		color: var(--charcoal-500);
		max-width: 600px;
	}

	.footer-decoration {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 2px;
	}

	.decoration-line {
		height: 100%;
		background: linear-gradient(90deg,
			var(--emerald-800) 0%,
			var(--emerald-500) 50%,
			var(--emerald-800) 100%
		);
		opacity: 0.5;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}

		.footer-brand {
			grid-column: 1 / -1;
			align-items: center;
			text-align: center;
		}

		.footer-tagline {
			max-width: none;
		}

		.footer-badges {
			justify-content: center;
		}
	}

	@media (max-width: 600px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}

		.footer-links-col {
			align-items: center;
			text-align: center;
		}
	}

	/* Light mode */
	html.light-mode .site-footer {
		background: #f1f3f5;
		border-top-color: #dee2e6;
	}
	html.light-mode .footer-logo-text { color: #101214; }
	html.light-mode .footer-tagline { color: #495057; }
	html.light-mode .footer-heading { color: #101214; }
	html.light-mode .footer-links a { color: #495057; }
	html.light-mode .footer-links a:hover { color: #16a34a; }
	html.light-mode .footer-badge { color: #16a34a; background: rgba(22,163,74,.08); border-color: rgba(22,163,74,.2); }
	html.light-mode .footer-divider { background: linear-gradient(90deg, transparent, #dee2e6, transparent); }
	html.light-mode .footer-copyright { color: #343a40; }
	html.light-mode .footer-disclaimer { color: #868e96; }
	html.light-mode .decoration-line { opacity: 0.3; }
</style>
